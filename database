import sqlite3
from datetime import datetime

class URLDatabase:
    def __init__(self, db_path='urls.db'):
        self.db_path = db_path
        self.init_db()

    def get_connection(self):
        conn = sqlite3.connect(self.db_path)
        conn.row_factory = sqlite3.Row
        return conn

    def init_db(self):
        with self.get_connection() as conn:
            conn.execute('''
                CREATE TABLE IF NOT EXISTS urls (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    original_url TEXT NOT NULL,
                    short_code TEXT UNIQUE NOT NULL,
                    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                    clicks INTEGER DEFAULT 0,
                    last_accessed TIMESTAMP,
                    is_custom BOOLEAN DEFAULT 0
                )
            ''')
            conn.execute('CREATE INDEX IF NOT EXISTS idx_short_code ON urls(short_code)')

    def add_url(self, original_url, short_code, is_custom=False):
        with self.get_connection() as conn:
            conn.execute(
                'INSERT INTO urls (original_url, short_code, is_custom) VALUES (?, ?, ?)',
                (original_url, short_code, is_custom)
            )
            return short_code

    def get_url(self, short_code):
        with self.get_connection() as conn:
            return conn.execute(
                'SELECT * FROM urls WHERE short_code = ?', (short_code,)
            ).fetchone()

    def code_exists(self, short_code):
        with self.get_connection() as conn:
            result = conn.execute(
                'SELECT COUNT(*) FROM urls WHERE short_code = ?', (short_code,)
            ).fetchone()
            return result[0] > 0

    def increment_clicks(self, short_code):
        with self.get_connection() as conn:
            conn.execute(
                'UPDATE urls SET clicks = clicks + 1, last_accessed = ? WHERE short_code = ?',
                (datetime.now(), short_code)
            )

    def get_stats(self, short_code):
        return self.get_url(short_code)

    def get_all_urls(self, limit=50):
        with self.get_connection() as conn:
            return conn.execute(
                'SELECT * FROM urls ORDER BY created_at DESC LIMIT ?', (limit,)
            ).fetchall()

    def delete_url(self, short_code):
        with self.get_connection() as conn:
            conn.execute('DELETE FROM urls WHERE short_code = ?', (short_code,))
